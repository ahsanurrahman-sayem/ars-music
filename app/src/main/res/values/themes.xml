<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme used by the app, overridden by Compose -->
    <style name="Theme.ArSync" parent="android:Theme.Material.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.ArSync.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A0A0F</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.ArSync</item>
    </style>
</resources>
